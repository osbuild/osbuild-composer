#!/usr/bin/python

import json
import re
from collections import defaultdict
from pathlib import Path

# Step 1: Read from /tmp/file
with open("/tmp/file", "r") as log_file:
    log_text = log_file.read()

# Step 2: Parse the log
update_map = defaultdict(list)
current_file = None

for line in log_text.strip().splitlines():
    if line.strip().endswith('.json:'):
        current_file = line.strip().rstrip(':')
    elif "NEWER:" in line:
        match = re.search(r'NEWER:\s*(\d+)\s+has a newer version\s*-\s*(\d+)', line)
        if match:
            old_version, new_version = match.groups()
            update_map[old_version].append(new_version)

# Step 3: Update the JSON file
if current_file:
    json_path = Path(current_file)
    if json_path.exists():
        with open(json_path, 'r') as f:
            data = json.load(f)

        def update_versions(obj):
            if isinstance(obj, dict):
                return {k: update_versions(v) for k, v in obj.items()}
            elif isinstance(obj, list):
                return [update_versions(item) for item in obj]
            elif isinstance(obj, str) and obj in update_map:
                return sorted(update_map[obj])[-1]
            else:
                return obj

        updated_data = update_versions(data)

        with open(json_path, 'w') as f:
            json.dump(updated_data, f, indent=4)

        print(f"Updated {json_path}")
    else:
        print(f"JSON file {json_path} not found.")
else:
    print("No JSON file referenced in the input.")

